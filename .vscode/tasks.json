{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build SFML Project",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-o", "wcwm.exe",
                "main.cpp",
                "-I", "./SFML/include",
                "-L", "./SFML/lib",
                "-lsfml-graphics-s",
                "-lsfml-window-s",
                "-lsfml-system-s",
                "-lopengl32",
                "-lfreetype",
                "-lgdi32",
                "-lwinmm",
                "-lole32",
                "-luuid",
                "-ldinput8",
                "-ldxguid",
                "-static-libgcc",
                "-static-libstdc++"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}